program -> stmt_list EOF
stmt_list -> stmt stmt_list | ε
stmt -> simple_stmt NEWLINE | if_stmt
simple_stmt -> assignment | print_stmt | expr | ε
assignment -> IDENTIFIER ASSIGN expr
print_stmt -> PRINT LPAREN expr RPAREN
if_stmt -> IF expr COLON NEWLINE INDENT stmt_list DEDENT elif_list else_part
elif_list -> elif_part elif_list | ε
elif_part -> ELIF expr COLON NEWLINE INDENT stmt_list DEDENT
else_part -> ELSE COLON NEWLINE INDENT stmt_list DEDENT | ε
expr -> and_expr OR expr | and_expr
and_expr -> not_expr AND and_expr | not_expr
not_expr -> NOT not_expr | rel_expr
rel_expr -> arith_expr rel_tail
rel_tail -> comp_op arith_expr rel_tail | ε
comp_op -> LESS_THAN | GREATER_THAN | LESS_EQUALS | GREATER_EQUALS | EQUALITY | NOT_EQUALS
arith_expr -> term PLUS arith_expr | term MINUS arith_expr | term
term -> power term_tail
term_tail -> STAR power term_tail | SLASH power term_tail | DOUBLE_SLASH power term_tail | MODULO power term_tail | ε
power -> factor DOUBLE_STAR power | factor
factor -> PLUS factor | MINUS factor | atom
atom -> INTEGER | FLOAT | STRING | IDENTIFIER | input_expr | list | LPAREN expr RPAREN
input_expr -> INPUT LPAREN RPAREN | INPUT LPAREN STRING RPAREN
list -> LBRACKET elements RBRACKET
elements -> expr element_tail | ε
element_tail -> COMMA expr element_tail | ε